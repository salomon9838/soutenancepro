{% extends 'base.html.twig' %}
{% block title %}{{ titre }}{% endblock %}
{% block body %}
<h3 class="mb-4">{{ titre }}</h3>
<div class="card" style="max-width: 700px;">
    <div class="card-body">
        {{ form_start(form) }}
            {{ form_row(form.etudiant) }}
            <div class="row">
                <div class="col-md-4">{{ form_row(form.president) }}</div>
                <div class="col-md-4">{{ form_row(form.rapporteur) }}</div>
                <div class="col-md-4">{{ form_row(form.examinateur) }}</div>
            </div>
            {{ form_row(form.salle) }}
            <div class="row">
                <div class="col-md-6">{{ form_row(form.date) }}</div>
                <div class="col-md-6">{{ form_row(form.heure) }}</div>
            </div>
            <button class="btn btn-primary mt-3"><i class="bi bi-check-circle"></i> Enregistrer</button>
            <a href="{{ path('soutenance_index') }}" class="btn btn-secondary mt-3">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
