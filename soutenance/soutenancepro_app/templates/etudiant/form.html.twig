{% extends 'base.html.twig' %}
{% block title %}{{ titre }}{% endblock %}
{% block body %}
<h3 class="mb-4">{{ titre }}</h3>
<div class="card" style="max-width: 600px;">
    <div class="card-body">
        {{ form_start(form) }}
            {{ form_row(form.nom) }}
            {{ form_row(form.prenom) }}
            {{ form_row(form.email) }}
            {{ form_row(form.filiere) }}
            {{ form_row(form.themeMemoire) }}
            <button class="btn btn-primary mt-3"><i class="bi bi-check-circle"></i> Enregistrer</button>
            <a href="{{ path('etudiant_index') }}" class="btn btn-secondary mt-3">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
