{% extends 'base.html.twig' %}
{% block title %}Étudiants{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Gestion des étudiants</h3>
    <a href="{{ path('etudiant_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Ajouter</a>
</div>

<form method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text" name="nom" value="{{ nom }}" class="form-control" placeholder="Rechercher par nom ou prénom...">
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary"><i class="bi bi-search"></i> Rechercher</button>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead><tr><th>Nom</th><th>Prénom</th><th>Email</th><th>Filière</th><th>Thème mémoire</th><th>Actions</th></tr></thead>
            <tbody>
            {% for e in etudiants %}
                <tr>
                    <td>{{ e.nom }}</td>
                    <td>{{ e.prenom }}</td>
                    <td>{{ e.email }}</td>
                    <td>{{ e.filiere }}</td>
                    <td>{{ e.themeMemoire }}</td>
                    <td>
                        <a href="{{ path('etudiant_edit', {id: e.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('etudiant_delete', {id: e.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cet étudiant ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ e.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-muted">Aucun étudiant enregistré.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
