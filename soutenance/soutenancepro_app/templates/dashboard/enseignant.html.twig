{% extends 'base.html.twig' %}
{% block title %}Tableau de bord Enseignant{% endblock %}
{% block body %}
<h3 class="mb-4">Tableau de bord — {{ enseignant ? enseignant : app.user.nomComplet }}</h3>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card card-stat p-3" style="background:#4f46e5;">
            <i class="bi bi-calendar-event fs-2"></i>
            <div class="display-6">{{ nbSoutenances }}</div>
            <div>Soutenances auxquelles je participe</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header fw-bold">Mes soutenances programmées</div>
    <div class="card-body">
        <table class="table table-hover">
            <thead><tr><th>Étudiant</th><th>Date</th><th>Heure</th><th>Salle</th></tr></thead>
            <tbody>
            {% for s in soutenances %}
                <tr>
                    <td>{{ s.etudiant }}</td>
                    <td>{{ s.date ? s.date|date('d/m/Y') : '' }}</td>
                    <td>{{ s.heure ? s.heure|date('H:i') : '' }}</td>
                    <td>{{ s.salle }}</td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-muted">Aucune soutenance programmée.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
