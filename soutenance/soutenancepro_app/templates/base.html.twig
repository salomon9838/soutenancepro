<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}SoutenancePro{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        body { background-color: #f4f6f9; }
        .sidebar { min-height: 100vh; background: #1e293b; color: #fff; }
        .sidebar a { color: #cbd5e1; text-decoration: none; display: block; padding: .65rem 1.2rem; border-radius: 6px; }
        .sidebar a:hover, .sidebar a.active { background: #334155; color: #fff; }
        .navbar-brand { font-weight: 700; letter-spacing: .5px; }
        .card-stat { border: none; border-radius: 12px; color: #fff; }
        .card-stat .display-6 { font-weight: 700; }
    </style>
</head>
<body>
{% if app.user %}
<div class="d-flex">
    <div class="sidebar p-3" style="width: 250px;">
        <div class="navbar-brand text-white mb-4 fs-5"><i class="bi bi-mortarboard-fill"></i> SoutenancePro</div>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_dashboard') }}"><i class="bi bi-speedometer2"></i> Tableau de bord</a>
            <a href="{{ path('etudiant_index') }}"><i class="bi bi-people"></i> Étudiants</a>
            <a href="{{ path('enseignant_index') }}"><i class="bi bi-person-badge"></i> Enseignants</a>
            <a href="{{ path('salle_index') }}"><i class="bi bi-door-open"></i> Salles</a>
            <a href="{{ path('soutenance_index') }}"><i class="bi bi-calendar-event"></i> Soutenances</a>
            <a href="{{ path('user_index') }}"><i class="bi bi-shield-lock"></i> Utilisateurs</a>
        {% elseif is_granted('ROLE_ENSEIGNANT') %}
            <a href="{{ path('enseignant_dashboard') }}"><i class="bi bi-speedometer2"></i> Tableau de bord</a>
            <a href="{{ path('enseignant_soutenances') }}"><i class="bi bi-calendar-event"></i> Mes soutenances</a>
            <a href="{{ path('enseignant_jurys') }}"><i class="bi bi-people"></i> Mes jurys</a>
        {% endif %}
        <hr class="text-secondary">
        <a href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-left"></i> Déconnexion</a>
    </div>
    <div class="flex-grow-1 p-4">
        <div class="d-flex justify-content-end mb-3">
            <span class="text-muted">Connecté : <strong>{{ app.user.nomComplet }}</strong></span>
        </div>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </div>
</div>
{% else %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    {% block body_public %}{% endblock %}
{% endif %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
