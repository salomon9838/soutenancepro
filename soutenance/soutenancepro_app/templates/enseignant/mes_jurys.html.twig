{% extends 'base.html.twig' %}
{% block title %}Mes jurys{% endblock %}
{% block body %}
<h3 class="mb-4">Mes jurys</h3>
<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead><tr><th>Étudiant</th><th>Date</th><th>Heure</th><th>Salle</th><th>Mon rôle</th></tr></thead>
            <tbody>
            {% for s in soutenances %}
                <tr>
                    <td>{{ s.etudiant }}</td>
                    <td>{{ s.date ? s.date|date('d/m/Y') : '' }}</td>
                    <td>{{ s.heure ? s.heure|date('H:i') : '' }}</td>
                    <td>{{ s.salle }}</td>
                    <td>
                        {% if s.president == enseignant %}Président{% endif %}
                        {% if s.rapporteur == enseignant %}Rapporteur{% endif %}
                        {% if s.examinateur == enseignant %}Examinateur{% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-muted">Aucun jury.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
