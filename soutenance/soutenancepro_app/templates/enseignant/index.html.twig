{% extends 'base.html.twig' %}
{% block title %}Enseignants{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Gestion des enseignants</h3>
    <a href="{{ path('enseignant_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Ajouter</a>
</div>
<div class="card">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead><tr><th>Nom</th><th>Prénom</th><th>Email</th><th>Spécialité</th><th>Actions</th></tr></thead>
            <tbody>
            {% for e in enseignants %}
                <tr>
                    <td>{{ e.nom }}</td>
                    <td>{{ e.prenom }}</td>
                    <td>{{ e.email }}</td>
                    <td>{{ e.specialite }}</td>
                    <td>
                        <a href="{{ path('enseignant_edit', {id: e.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('enseignant_delete', {id: e.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cet enseignant ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ e.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-muted">Aucun enseignant enregistré.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
